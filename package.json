{
  "name": "naughtybox",
  "private": true,
  "description": "Realtime streaming platform monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "npm run dev -w @naughtybox/backend",
    "streaming:dev": "npm run dev -w @naughtybox/streaming",
    "frontend:dev": "npm run start -w @naughtybox/frontend",
    "build": "npm run build -w @naughtybox/backend && npm run build -w @naughtybox/streaming && npm run build -w @naughtybox/frontend"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "primeicons": "^7.0.0",
    "primeng": "^17.18.15"
  }
}
